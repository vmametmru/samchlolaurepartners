# Apache configuration for the React SPA (react-router-dom BrowserRouter).
# Vite copies this file from public/ into dist/ at build time, so it ends up
# at the deployment root alongside index.html.
#
# Requests to /api/* are handled separately by the Node.js app (see the
# Passenger configuration in api/.htaccess) and must not be rewritten here.

<IfModule mod_rewrite.c>
  RewriteEngine On

  # Let requests targeting the Node.js API pass through untouched.
  RewriteRule ^api/ - [L]

  # Serve existing files and directories as-is (assets, favicon, etc.).
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Everything else falls back to index.html so React Router can handle it.
  RewriteRule ^ index.html [L]
</IfModule>
