# Environment Variables

APP_ENV=development
PORT=8080
APP_URL=http://localhost:8080

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=partners_user
DB_PASSWORD=partners_pass
DB_NAME=partners_db

# Auth
JWT_SECRET=change-me-to-a-long-random-secret
# Optional override for the auth cookie's Domain. By default the cookie is shared
# across the registrable domain (e.g. logging in on any *.grand-baie-maurice.com host
# keeps the session on the apex and every partner subdomain), which is what a
# multi-tenant setup needs. Set this only to force a specific value, e.g.
# ".example.com" to share, or a single host to restrict the cookie to one host.
APP_COOKIE_DOMAIN=

# Lodgify API (server-side only — never expose to frontend)
LODGIFY_API_KEY=your-lodgify-api-key-here
LODGIFY_BASE_URL=https://api.lodgify.com/v2

# Default SMTP fallback (per-partner SMTP overrides this)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=no-reply@example.com
SMTP_FROM_NAME=samchlolaurepartners

# Admin seed credentials (used by install/install.php / optional seeds)
ADMIN_EMAIL=admin@mauritius-booking.com
ADMIN_PASSWORD=changeme

# CORS — kept for compatibility with external API clients
CORS_ORIGIN=http://localhost:8080

# Comma-separated IPs of reverse proxies allowed to set X-Forwarded-Host for
# subdomain-based tenant resolution. Leave empty if the app is reached directly
# (no proxy) — X-Forwarded-Host is otherwise ignored to prevent tenant spoofing.
TRUSTED_PROXIES=
