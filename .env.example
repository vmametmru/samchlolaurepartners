# Environment Variables

# ─── Backend ───────────────────────────────────────────
PORT=3000
NODE_ENV=development

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=partners_user
DB_PASSWORD=partners_pass
DB_NAME=partners_db

# JWT
JWT_SECRET=change-me-to-a-long-random-secret

# Lodgify API (server-side only — never expose to frontend)
LODGIFY_API_KEY=your-lodgify-api-key-here
LODGIFY_BASE_URL=https://api.lodgify.com/v2

# Default SMTP fallback (per-partner SMTP overrides this)
SMTP_HOST=localhost
SMTP_PORT=1025

# Admin seed credentials (used by database/seeds/001_admin_user.sql)
ADMIN_EMAIL=admin@mauritius-booking.com
ADMIN_PASSWORD=changeme

# CORS — comma-separated list of allowed frontend origins
CORS_ORIGIN=http://localhost:5173

# ─── Frontend ──────────────────────────────────────────
VITE_API_URL=http://localhost:3000
VITE_MAP_TILE_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png
